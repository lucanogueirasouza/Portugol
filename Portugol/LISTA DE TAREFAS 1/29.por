programa {
  funcao inicio() {
    real n1, n2, r

    escreva("Escreva o primeiro número: ")
    leia(n1)

    escreva("Escreva o segundo número: ")
    leia(n2)

    se (n1 == n2) {
      escreva("Os dois números são iguais.")
    } senao {
      escreva("Os dois números são diferentes.")
    }
  }
}